<script>
// ── PPT ──
var pptCur = 0;
var pptSlides = document.querySelectorAll('.ppt-slide');
var pptTotal = pptSlides.length;

// Build thumbs
var thumbsEl = document.getElementById('pptThumbs');
var thumbBgs = ['#0d2137','#fff','#fff','#fff','#fff'];
var thumbColors = ['#7EB8F7','#1B3F6E','#1B3F6E','#1B3F6E','#1B3F6E'];
var thumbLabels = ['Portada','¿Qué es ISO?','7 Principios','PDCA','Resumen'];
thumbLabels.forEach(function(l,i){
  var t = document.createElement('div');
  t.className = 'ppt-thumb' + (i===0?' on':'');
  var inner = document.createElement('div');
  inner.className = 'ppt-thumb-inner';
  inner.style.background = thumbBgs[i];
  inner.style.color = thumbColors[i];
  inner.textContent = l;
  t.appendChild(inner);
  t.onclick = (function(n){return function(){pptJump(n);};})(i);
  thumbsEl.appendChild(t);
});

function pptJump(n){
  pptSlides[pptCur].classList.remove('active');
  document.querySelectorAll('.ppt-thumb')[pptCur].classList.remove('on');
  pptCur = n;
  pptSlides[pptCur].classList.add('active');
  document.querySelectorAll('.ppt-thumb')[pptCur].classList.add('on');
  document.getElementById('pptCounter').textContent = (pptCur+1)+' / '+pptTotal;
  document.getElementById('pptPrev').disabled = pptCur===0;
  document.getElementById('pptNext').disabled = pptCur===pptTotal-1;
}
function pptGo(d){ pptJump(pptCur+d); }

// ── QUIZ ──
var qScore = 0;
var qAnswered = {};
var qCorrect = [2,1,0,2];
var qFeedbacks = [
  'La versión actual es de <strong>2015</strong>, quinta edición que incorporó el pensamiento basado en riesgos y el contexto organizacional.',
  'La norma se basa en <strong>7 principios</strong>: Enfoque en el cliente, Liderazgo, Compromiso de personas, Procesos, Mejora, Evidencia y Relaciones.',
  '<strong>Correcto.</strong> PDCA = Planificar (Plan), Hacer (Do), Verificar (Check), Actuar (Act). Es la columna vertebral de ISO 9001.',
  'La estructura de alto nivel tiene <strong>10 cláusulas</strong>. Las primeras 3 son introductorias; las cláusulas 4-10 son los requisitos del SGC.'
];

function answerQ(qi, ai, correct){
  if(qAnswered[qi] !== undefined) return;
  qAnswered[qi] = ai;
  var opts = document.querySelectorAll('#q'+qi+' .q-opt');
  opts.forEach(function(o){ o.disabled = true; });
  if(ai === correct){
    opts[ai].classList.add('correct');
    opts[ai].querySelector('.q-ltr').textContent = '✓';
    qScore++;
  } else {
    opts[ai].classList.add('wrong');
    opts[correct].classList.add('correct');
    opts[ai].querySelector('.q-ltr').textContent = '✗';
  }
  var fb = document.getElementById('fb'+qi);
  fb.innerHTML = qFeedbacks[qi];
  fb.className = 'q-feedback show ' + (ai===correct?'ok':'err');
  document.getElementById('next'+qi).classList.add('show');
  // update progress
  var answered = Object.keys(qAnswered).length;
  document.getElementById('quizFill').style.width = Math.round(answered/4*100)+'%';
}

function nextQ(n){
  document.getElementById('q'+(n-1)).classList.remove('active');
  document.getElementById('q'+n).classList.add('active');
}

function showResult(){
  document.getElementById('q3').classList.remove('active');
  var pct = Math.round(qScore/4*100);
  var passed = pct >= 75;
  var result = document.getElementById('quizResult');
  var circle = document.getElementById('qrCircle');
  var col = passed ? '#4ade80' : pct>=50 ? '#fbbf24' : '#f87171';
  circle.style.borderColor = col;
  circle.style.color = col;
  circle.textContent = pct+'%';
  document.getElementById('qrTitle').textContent = passed ? '¡Excelente!' : 'Sigue practicando';
  document.getElementById('qrTitle').style.color = col;
  document.getElementById('qrSub').innerHTML = qScore+' de 4 correctas.<br>'+(passed?'¡Superaste el umbral de aprobación! Ya sabes lo básico de ISO 9001.':'Repasa el contenido e intenta nuevamente. ¡Tú puedes!');
  document.getElementById('quizFill').style.width = '100%';
  result.classList.add('show');
}

function retryQuiz(){
  qScore=0; qAnswered={};
  document.getElementById('quizFill').style.width='0%';
  document.getElementById('quizResult').classList.remove('show');
  document.querySelectorAll('.q-step').forEach(function(s,i){
    s.classList.remove('active');
    s.querySelectorAll('.q-opt').forEach(function(o){
      o.disabled=false;
      o.classList.remove('correct','wrong');
      o.querySelector('.q-ltr').textContent=['A','B','C','D'][Array.from(s.querySelectorAll('.q-opt')).indexOf(o)];
    });
    var fb=s.querySelector('.q-feedback');
    fb.className='q-feedback';
    s.querySelector('.q-next').classList.remove('show');
  });
  document.getElementById('q0').classList.add('active');
}
</script>
