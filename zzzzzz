<!-- PPT DEMO -->
<section class="ppt-section" id="demo-ppt">
  <div class="ppt-wrap">
    <div class="ppt-header">
      <div>
        <div class="section-label">Actividad interactiva</div>
        <h2 class="section-title">Así se ven tus<br><em>diapositivas digitales</em></h2>
      </div>
      <p class="section-sub" style="padding-top:32px;">Navega las slides igual que en el curso real. Cada diapositiva es interactiva y adaptada a pantalla completa o móvil.</p>
    </div>

    <div class="ppt-stage">
      <div class="ppt-topbar">
        <div class="ppt-dots">
          <div class="ppt-dot" style="background:#f87171"></div>
          <div class="ppt-dot" style="background:#fbbf24"></div>
          <div class="ppt-dot" style="background:#4ade80"></div>
        </div>
        <div class="ppt-title-bar">ISO 9001:2015 — Vista previa</div>
        <div class="ppt-counter" id="pptCounter">1 / 5</div>
      </div>

      <div class="ppt-slides">
        <!-- Slide 1: Portada -->
        <div class="ppt-slide active">
          <div class="sl-cover">
            <div class="sl-cover-badge">Norma Internacional · ISO</div>
            <h2>ISO <em>9001:2015</em><br>Sistema de Gestión de Calidad</h2>
            <p>Aprende a implementar y comprender los requisitos del estándar de calidad más reconocido del mundo.</p>
            <div class="sl-cover-units">
              <div class="sl-cover-unit"><strong>Unidad 1</strong>Fundamentos</div>
              <div class="sl-cover-unit"><strong>Unidad 2</strong>Requisitos</div>
