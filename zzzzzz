<!-- STATS -->
<section class="section" style="padding-top:0;">
  <div class="stats-row">
    <div class="stat-box"><div class="stat-n">72h</div><div class="stat-l">Entrega promedio</div></div>
    <div class="stat-box"><div class="stat-n">100%</div><div class="stat-l">Cumplimiento SENCE</div></div>
    <div class="stat-box"><div class="stat-n">+50</div><div class="stat-l">Cursos migrados</div></div>
    <div class="stat-box"><div class="stat-n">0</div><div class="stat-l">Conocimientos técnicos</div></div>
